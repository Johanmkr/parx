      "id": "Hstk",
      "code_hash": "b3944c60b0a343b134545c98bc1537c7",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><div class=\"language-python codehilite\"><pre><span></span><code><span class=\"c1\"># From PyTorch module</span>\n<span class=\"n\">network</span> <span class=\"o\">=</span> <span class=\"n\">nn</span><span class=\"o\">.</span><span class=\"n\">Sequential</span><span class=\"p\">(</span><span class=\"n\">nn</span><span class=\"o\">.</span><span class=\"n\">Linear</span><span class=\"p\">(</span><span class=\"mi\">2</span><span class=\"p\">,</span><span class=\"mi\">10</span><span class=\"p\">),</span> <span class=\"n\">nn</span><span class=\"o\">.</span><span class=\"n\">ReLU</span><span class=\"p\">(),</span> <span class=\"n\">nn</span><span class=\"o\">.</span><span class=\"n\">Linear</span><span class=\"p\">(</span><span class=\"mi\">10</span><span class=\"p\">,</span><span class=\"mi\">1</span><span class=\"p\">))</span>\n<span class=\"n\">loaded</span> <span class=\"o\">=</span> <span class=\"n\">parx</span><span class=\"o\">.</span><span class=\"n\">load_network</span><span class=\"p\">(</span><span class=\"n\">network</span><span class=\"p\">)</span>\n\n<span class=\"c1\"># From saved state dict</span>\n<span class=\"n\">loaded</span> <span class=\"o\">=</span> <span class=\"n\">parx</span><span class=\"o\">.</span><span class=\"n\">load_network</span><span class=\"p\">(</span><span class=\"s2\">&quot;model.pth&quot;</span><span class=\"p\">)</span>\n<span class=\"n\">loaded</span> <span class=\"o\">=</span> <span class=\"n\">parx</span><span class=\"o\">.</span><span class=\"n\">load_network</span><span class=\"p\">(</span><span class=\"n\">torch</span><span class=\"o\">.</span><span class=\"n\">load</span><span class=\"p\">(</span><span class=\"s2\">&quot;model.pth&quot;</span><span class=\"p\">))</span>\n\n<span class=\"c1\"># From HDF5 (requires pip install parx[h5])</span>\n<span class=\"n\">loaded</span> <span class=\"o\">=</span> <span class=\"n\">parx</span><span class=\"o\">.</span><span class=\"n\">load_network</span><span class=\"p\">(</span><span class=\"s2\">&quot;model.h5&quot;</span><span class=\"p\">)</span>\n\n<span class=\"c1\"># Manual specification</span>\n<span class=\"n\">weights</span> <span class=\"o\">=</span> <span class=\"p\">[</span><span class=\"n\">W1</span><span class=\"p\">,</span> <span class=\"n\">W2</span><span class=\"p\">,</span> <span class=\"n\">W3</span><span class=\"p\">]</span>  <span class=\"c1\"># List of numpy arrays</span>\n<span class=\"n\">biases</span> <span class=\"o\">=</span> <span class=\"p\">[</span><span class=\"n\">b1</span><span class=\"p\">,</span> <span class=\"n\">b2</span><span class=\"p\">,</span> <span class=\"n\">b3</span><span class=\"p\">]</span>   <span class=\"c1\"># List of numpy arrays</span>\n<span class=\"n\">loaded</span> <span class=\"o\">=</span> <span class=\"n\">parx</span><span class=\"o\">.</span><span class=\"n\">load_network</span><span class=\"p\">((</span><span class=\"n\">weights</span><span class=\"p\">,</span> <span class=\"n\">biases</span><span class=\"p\">))</span>\n</code></pre></div>\n<h3 id=\"partition-computation\">Partition Computation</h3>\n<div class=\"language-python codehilite\"><pre><span></span><code><span class=\"n\">partition</span> <span class=\"o\">=</span> <span class=\"n\">parx</span><span class=\"o\">.</span><span class=\"n\">compute_partition</span><span class=\"p\">(</span>\n    <span class=\"n\">network</span><span class=\"p\">,</span>           <span class=\"c1\"># Network (any supported format)</span>\n    <span class=\"n\">bounds</span><span class=\"p\">,</span>           <span class=\"c1\"># List of [min, max] for each input dimension</span>\n    <span class=\"n\">method</span><span class=\"o\">=</span><span class=\"s1\">&#39;sparse&#39;</span><span class=\"p\">,</span>  <span class=\"c1\"># &#39;sparse&#39; (fast) or &#39;exact&#39; (complete)</span>\n    <span class=\"n\">max_regions</span><span class=\"o\">=</span><span class=\"mi\">1000</span>  <span class=\"c1\"># Optional limit for sparse method</span>\n<span class=\"p\">)</span>\n\n<span class=\"c1\"># Partition properties</span>\n<span class=\"nb\">len</span><span class=\"p\">(</span><span class=\"n\">partition</span><span class=\"o\">.</span><span class=\"n\">regions</span><span class=\"p\">)</span>              <span class=\"c1\"># Number of regions found</span>\n<span class=\"n\">partition</span><span class=\"o\">.</span><span class=\"n\">input_dim</span>                 <span class=\"c1\"># Input space dimension</span>\n<span class=\"n\">partition</span><span class=\"o\">.</span><span class=\"n\">output_dim</span>                <span class=\"c1\"># Output dimension</span>\n\n<span class=\"c1\"># Region access</span>\n<span class=\"n\">region</span> <span class=\"o\">=</span> <span class=\"n\">partition</span><span class=\"o\">.</span><span class=\"n\">regions</span><span class=\"p\">[</span><span class=\"mi\">0</span><span class=\"p\">]</span>       <span class=\"c1\"># Get specific region</span>\n<span class=\"n\">region</span><span class=\"o\">.</span><span class=\"n\">activation_path</span>              <span class=\"c1\"># Binary pattern of active neurons</span>\n<span class=\"n\">region</span><span class=\"o\">.</span><span class=\"n\">centroid</span>                     <span class=\"c1\"># Representative point in region</span>\n<span class=\"n\">region</span><span class=\"o\">.</span><span class=\"n\">active_indices</span>               <span class=\"c1\"># Which neurons are active</span>\n<span class=\"n\">region</span><span class=\"o\">.</span><span class=\"n\">bounded</span>                      <span class=\"c1\"># Whether region is bounded</span>\n</code></pre></div>\n<h3 id=\"region-queries-geometry\">Region Queries &amp; Geometry</h3>\n<div class=\"language-python codehilite\"><pre><span></span><code><span class=\"c1\"># Route points to regions</span>\n<span class=\"n\">points</span> <span class=\"o\">=</span> <span class=\"p\">[[</span><span class=\"mf\">0.5</span><span class=\"p\">,</span> <span class=\"o\">-</span><span class=\"mf\">0.3</span><span class=\"p\">],</span> <span class=\"p\">[</span><span class=\"mf\">1.2</span><span class=\"p\">,</span> <span class=\"mf\">0.8</span><span class=\"p\">]]</span>\n<span class=\"n\">region_ids</span> <span class=\"o\">=</span> <span class=\"n\">partition</span><span class=\"o\">.</span><span class=\"n\">route</span><span class=\"p\">(</span><span class=\"n\">points</span><span class=\"p\">)</span>     <span class=\"c1\"># Returns region indices or None</span>\n\n<span class=\"c1\"># Extract region geometry</span>\n<span class=\"n\">D</span><span class=\"p\">,</span> <span class=\"n\">g</span> <span class=\"o\">=</span> <span class=\"n\">partition</span><span class=\"o\">.</span><span class=\"n\">halfspaces</span><span class=\"p\">(</span><span class=\"n\">region</span><span class=\"p\">)</span>      <span class=\"c1\"># Get Dx \u2264 g constraints</span>\n<span class=\"n\">vertices</span> <span class=\"o\">=</span> <span class=\"n\">partition</span><span class=\"o\">.</span><span class=\"n\">vertices</span><span class=\"p\">(</span><span class=\"n\">region</span><span class=\"p\">)</span>    <span class=\"c1\"># Extract vertices (2D only)</span>\n\n<span class=\"c1\"># Analyze regions by layer</span>\n<span class=\"n\">layer_regions</span> <span class=\"o\">=</span> <span class=\"n\">partition</span><span class=\"o\">.</span><span class=\"n\">regions_at_layer</span><span class=\"p\">(</span><span class=\"mi\">1</span><span class=\"p\">)</span>  <span class=\"c1\"># Regions split by layer 1</span>\n</code></pre></div></span>"
          }
        }
      ],
      "console": []
